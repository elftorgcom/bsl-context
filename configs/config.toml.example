# bsl-context-rs — пример конфига.
# Скопировать в configs/config.toml и подправить под свою машину.
# Запуск: bsl-context-rs.exe --config C:\tools\bsl-context-rs\configs\config.toml

# Адрес для bind. Loopback по дефолту — наружу не торчим.
host = "127.0.0.1"

# Порт MCP-сервера. 8007 свободен после декомиссии bsl-platform-context (карточка #252).
port = 8007

# Внешний домен для генерации инструкций на стартовой странице (необязательно).
# Если не задан, страница автоматически определяет адрес через window.location.origin.
# external_domain = "bsl-context.alwaysdata.net"

# Каталог установки 1С — ОБЯЗАТЕЛЬНО указать явно.
# Внутри должен быть файл shcntx_ru.hbk (синтакс-помощник платформы).
#
# На корпоративных машинах часто стоит несколько версий рядом:
#   C:\Program Files\1cv8\8.3.18.1563\
#   C:\Program Files\1cv8\8.3.21.1624\
#   C:\Program Files\1cv8\8.3.25.1257\
#   C:\Program Files\1cv8\8.3.27.1606\
#   C:\Program Files\1cv8\8.3.27.1786\
# Сервер автоматически НЕ выбирает версию — это ваше осознанное решение,
# потому что в разных версиях платформы могут отличаться сигнатуры методов
# и состав системных перечислений. Укажите ту версию, под которую
# валидируете код. Если оставить поле пустым/закомментировать — сервер
# стартует с /health, но загрузка индекса будет недоступна.
platform_path = 'C:\Program Files\1cv8\8.3.27.1786'

# Каталог логов. run.bat создаёт его до запуска бинарника.
# Туда пишутся: service.YYYY-MM-DD.log (через tracing-appender), stdout.log, stderr.log.
log_dir = 'C:\bsl-context-rs\logs'

# tracing-фильтр. Можно поменять на debug при отладке.
log_level = "info"

# Дефолтный уровень для validate_expression, когда клиент не передал параметр level.
# 1 — статический анализ ссылок с явным именем типа в исходнике (низкий шум, безопасный дефолт).
# 2 — дополнительно локальный type inference в пределах процедуры (Phase 8 MVP):
#     `Х = Новый ТипX`, `Х = ТипY.ЗначениеZ`, `// @type ТипX`. Больше находок, но и больше
#     потенциальных false-positive из-за динамической типизации BSL.
# Значение клампится в [1..=2]. Опечатки в этом поле сервер не валит — просто берёт ближайший
# допустимый уровень.
default_validation_level = 1
